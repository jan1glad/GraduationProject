        <script><![CDATA[(function executeRule(current, previous) {

    if (current.getValue('state') != '3') {
        return;
    }

    if (previous.getValue('state') == '3') {
        return;
    }

    var userGr = new GlideRecord('sys_user');
    if (!userGr.get(current.getValue('opened_by'))) {
        return;
    }

    var remaining = parseInt(userGr.getValue('u_left_paid_days_leave'), 10) || 0;
    var requested = parseInt(current.getValue('u_working_days'), 10) || 0;

    userGr.setValue('u_left_paid_days_leave', remaining - requested);
    userGr.update();

})(current, previous);]]></script>
