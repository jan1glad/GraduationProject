        <script><![CDATA[(function executeRule(current, previous) {

    if (current.getValue('state') != '3') {
        return;
    }

    if (!current.getValue('u_onboarding_case')) {
        return;
    }

    var gr = new GlideRecord('u_onboarding_task');
    gr.addQuery('u_onboarding_case', current.getValue('u_onboarding_case'));
    gr.addQuery('sys_id', '!=', current.getUniqueValue());
    gr.addQuery('state', '!=', '3');
    gr.query();

    if (gr.hasNext()) {
        return;
    }

    var caseGr = new GlideRecord('u_onboarding_case');
    var caseId = current.getValue('u_onboarding_case');

    if (!caseGr.get(caseId)) {
        return;
    }

    caseGr.setValue('u_state', 'closed_completed');
    caseGr.update();

})(current, previous);]]></script>
