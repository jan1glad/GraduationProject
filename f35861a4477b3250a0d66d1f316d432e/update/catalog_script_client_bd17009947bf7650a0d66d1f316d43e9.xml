        <name>Days after leave</name>
        <order/>
        <published_ref/>
        <script><![CDATA[function onChange(control, oldValue, newValue, isLoading) {
    if (isLoading) {
        return;
    }

    var remaining = g_form.getValue('left_paid_days_leave');
    var requested = g_form.getValue('u_working_days');

    if (!remaining || !requested) {
        g_form.setValue('after_this_leave', '');
        return;
    }

    remaining = parseInt(remaining, 10);
    requested = parseInt(requested, 10);

    var result = remaining - requested;

    if (result < 0) {
    g_form.addErrorMessage('You do not have enough leave days.');
}

    g_form.setValue('after_this_leave', result);
}]]></script>
